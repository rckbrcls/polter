{
  "name": "@polterware/polter",
  "version": "0.2.1",
  "description": "An interactive CLI for managing Supabase CLI workflows.",
  "type": "module",
  "bin": {
    "polter": "./dist/index.js",
    "polter-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/polterware/polter.git"
  },
  "bugs": {
    "url": "https://github.com/polterware/polter/issues"
  },
  "homepage": "https://github.com/polterware/polter#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup src/index.tsx src/api.ts src/mcp.ts --watch --format esm --dts",
    "build": "tsup src/index.tsx src/api.ts src/mcp.ts --format esm --clean",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "polterware",
    "polter",
    "cli",
    "typescript"
  ],
  "author": "Polterware",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "conf": "^15.1.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
