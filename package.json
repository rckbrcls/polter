{
  "name": "@polterware/polter",
  "version": "0.6.3",
  "description": "Infrastructure orchestrator CLI for managing dev processes, pipelines, CLI commands, and packages.",
  "type": "module",
  "bin": {
    "polter": "./dist/index.js",
    "polter-mcp": "./dist/mcp.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/polterware/polter.git"
  },
  "bugs": {
    "url": "https://github.com/polterware/polter/issues"
  },
  "homepage": "https://github.com/polterware/polter#readme",
  "scripts": {
    "dev": "tsup src/index.tsx src/api.ts src/mcp.ts --watch --format esm --dts",
    "build": "tsup src/index.tsx src/api.ts src/mcp.ts --format esm --clean",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:bin": "bun run build:bin:polter && bun run build:bin:mcp",
    "build:bin:polter": "bun build --compile src/index.tsx --outfile dist/bin/polter",
    "build:bin:mcp": "bun build --compile src/mcp.ts --outfile dist/bin/polter-mcp",
    "build:all": "bun run build && bun run build:bin"
  },
  "keywords": [
    "polterware",
    "polter",
    "cli",
    "orchestrator",
    "infrastructure",
    "pipelines",
    "supabase",
    "github",
    "vercel",
    "git",
    "typescript"
  ],
  "author": "Polterware",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cli-spinners": "^3.4.0",
    "conf": "^15.1.0",
    "eventemitter3": "^5.0.4",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "ink": "^6.8.0",
    "ink-big-text": "^2.0.0",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "ink-text-input": "^6.0.0",
    "ms": "^2.1.3",
    "p-limit": "^7.3.0",
    "p-retry": "^7.1.1",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "semver": "^7.7.4",
    "signal-exit": "^4.1.0",
    "which": "^6.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/ms": "^2.1.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.0",
    "@types/semver": "^7.7.1",
    "@types/which": "^3.0.4",
    "react-devtools-core": "^7.0.1",
    "tsup": "^8.3.6",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
