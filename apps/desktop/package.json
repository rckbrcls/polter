{
  "name": "@polterware/desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Electron desktop shell for Polter.",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "pnpm build && electron-builder --publish never",
    "dist:mac": "pnpm build && electron-builder --mac --publish never",
    "dist:win": "pnpm build && electron-builder --win --publish never",
    "dist:linux": "pnpm build && electron-builder --linux --publish never",
    "dist:all": "pnpm build && electron-builder -mwl --publish never",
    "design:lint": "design.md lint DESIGN.md",
    "deps:electron": "node -e \"const pkg = require('./package.json'); console.log(pkg.devDependencies.electron);\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@orama/orama": "^3.1.18",
    "@polterware/core": "workspace:*"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@google/design.md": "^0.1.1",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/react-query": "^5.100.1",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-log": "^5.4.3",
    "electron-vite": "^5.0.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "jsdom": "^29.0.2",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-resizable-panels": "^4.10.0",
    "recharts": "3.8.0",
    "shadcn": "^4.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.12",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vaul": "^1.1.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.5",
    "zustand": "^5.0.12"
  }
}
